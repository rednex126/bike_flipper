# =========================================================================
#  BIKE FLIPPER - CONFIGURATION FOR DEPLOYMENT (RENDER.COM & LOCAL)
# =========================================================================
# Save this file as '.env' for local testing. 
# For Render.com, set these variables in the Render Dashboard -> "Environment" tab.

# 1. NODE ENVIRONMENT (Set this to 'production' on Render.com)
NODE_ENV=development

# 2. PORT (Render sets this automatically, but you can set it to override)
PORT=3000

# 3. GOOGLE GEMINI API KEY (REQUIRED for the AI appraiser/scorer)
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 4. TELEGRAM BOT SETTINGS (Optional, for notifications)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_MIN_MARGIN=30
TELEGRAM_MIN_SCORE=75

# NOTE FOR RENDER.COM DEPLOYMENT:
# In your Render service configuration:
# - Build Command: npm run build
# - Start Command: npm start
# - Environment Variables: Add 'GEMINI_API_KEY' and 'NODE_ENV' under Environment tab!
